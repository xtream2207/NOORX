# =============================================
# 🚀 NOOR-X BOT - ENVIRONMENT CONFIGURATION
# =============================================

# Node Environment
NODE_ENV=production

# =============================================
# 🌐 SERVER CONFIGURATION
# =============================================
PORT=3000
HOST=localhost
BASE_URL=http://localhost:3000

# =============================================
# 🔐 ADMIN CREDENTIALS
# =============================================
# Change these immediately in production!
ADMIN_USER=admin
ADMIN_PASS=noorx2024
SESSION_SECRET=order

# =============================================
# 📱 WHATSAPP CONFIGURATION
# =============================================
# Your WhatsApp channel ID to check membership
WHATSAPP_CHANNEL_ID=0029Vb7vchCCBtxK3Ria2k1i
WHATSAPP_CHANNEL_URL=https://whatsapp.com/channel/0029Vb7vchCCBtxK3Ria2k1i

# =============================================
# ⏱️ TIMING CONFIGURATION
# =============================================
# Channel check interval (in hours)
CHANNEL_CHECK_INTERVAL=10

# Pairing timeout (in milliseconds)
PAIRING_TIMEOUT=120000

# =============================================
# 💾 DATABASE (Optional - for future use)
# =============================================
# DATABASE_URL=mongodb://localhost:27017/noorx
# DB_TYPE=mongodb

# =============================================
# 📊 LOGGING
# =============================================
LOG_LEVEL=info
LOG_FILE=./logs/bot.log

# =============================================
# 🔒 SECURITY
# =============================================
# Enable HTTPS (for production)
USE_HTTPS=false
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# =============================================
# 📢 NOTIFICATIONS (Optional)
# =============================================
# Telegram bot token for notifications
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_ADMIN_ID=your_admin_id_here

# =============================================
# 🎯 BOT CONFIGURATION
# =============================================
BOT_NAME=NOOR-X
BOT_PREFIX=!
MAX_MESSAGE_LENGTH=4096

# =============================================
# 📝 NOTES
# =============================================
# 1. Copy this file to .env
# 2. Fill in all required values
# 3. Keep .env in .gitignore (never commit!)
# 4. Change admin credentials immediately
# 5. Use strong session secret in production

